{
  "manifest_version": 3,
  "name": "Discord Self Message Cleaner",
  "version": "0.5.0",
  "description": "Batch-delete your own Discord messages. Floating panel injected into Discord.",
  "author": "mzrodyu / catie",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://discord.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "Discord Self Message Cleaner"
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/*"],
      "js": ["cleaner.user.js"],
      "run_at": "document_idle"
    }
  ]
}
